{
  "name": "world-cup-simplified",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.7",
  "scripts": {
    "audit": "node scripts/audit-data.mjs",
    "audit:copy": "node scripts/audit-matchup-copy.mjs",
    "audit:schedule": "node scripts/audit-fifa-schedule.mjs",
    "history:goals": "node scripts/sync-historical-goal-events.mjs",
    "import:history": "node scripts/import-world-cup-history.mjs",
    "history:matchups": "node scripts/populate-historical-matchup-key-information.mjs",
    "history:images": "node scripts/populate-historical-player-images.mjs",
    "history:profiles": "node scripts/populate-historical-player-profiles.mjs",
    "matchups": "node scripts/populate-matchup-key-information.mjs",
    "matchday:update": "node scripts/matchday-update.mjs",
    "matchday:readiness": "node scripts/matchday-readiness.mjs",
    "profiles": "node scripts/populate-player-profiles.mjs",
    "cards:check": "node scripts/audit-player-card-coverage.mjs",
    "results": "node scripts/populate-result-highlights.mjs",
    "results:check": "node scripts/audit-result-enrichment.mjs",
    "sync:fifa:goals": "node scripts/sync-fifa-goal-events.mjs",
    "smoke": "node scripts/ui-smoke.mjs",
    "sync:fifa": "node scripts/sync-fifa-results.mjs",
    "sync:fifa:pr": "node scripts/sync-fifa-results.mjs --skip-unchanged",
    "test": "node scripts/validate-data.mjs && node scripts/audit-data.mjs && node scripts/audit-result-enrichment.mjs && node scripts/audit-player-card-coverage.mjs && node scripts/ui-smoke.mjs",
    "validate": "node scripts/validate-data.mjs",
    "release-notes:check": "node scripts/validate-release-notes.mjs"
  },
  "devDependencies": {
    "playwright": "1.60.0"
  }
}
